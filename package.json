{
  "name": "ownables-js",
  "private": true,
  "version": "0.1.0",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A -t run build",
    "build:packages": "yarn workspaces foreach -A -t --no-private run build",
    "build:ownable": "bash contracts/ownable-static/scripts/build.sh",
    "clean": "yarn workspaces foreach -A run clean",
    "typecheck": "yarn workspaces foreach -A -t run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:contract:ownable-static:manifest": "node contracts/ownable-static/scripts/check-code-hash-manifest.mjs",
    "test:watch": "vitest",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "workspaces:list": "yarn workspaces list --verbose",
    "semantic-release": "semantic-release"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
