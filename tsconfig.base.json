{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@ownables/core": ["packages/core/src/index.ts"],
      "@ownables/core/*": ["packages/core/src/*"],
      "@ownables/platform-browser": ["packages/platform-browser/src/index.ts"],
      "@ownables/platform-browser/*": ["packages/platform-browser/src/*"],
      "@ownables/adapter-viem": ["packages/adapter-viem/src/index.ts"],
      "@ownables/adapter-viem/*": ["packages/adapter-viem/src/*"],
      "@ownables/builder-client": ["packages/builder-client/src/index.ts"],
      "@ownables/builder-client/*": ["packages/builder-client/src/*"],
      "@ownables/platform-node": ["packages/platform-node/src/index.ts"],
      "@ownables/platform-node/*": ["packages/platform-node/src/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false
  }
}
